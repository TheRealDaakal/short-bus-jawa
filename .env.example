# Copy this file to .env and fill in your values. Never commit .env itself.

# Required: your bot's token from the Discord Developer Portal
DISCORD_TOKEN=

# Optional: set this to a guild ID to sync slash commands instantly to
# one test server during development. Leave blank in production.
DEV_GUILD_ID=

# Optional: DEBUG, INFO, WARNING, ERROR. Defaults to INFO.
LOG_LEVEL=INFO
